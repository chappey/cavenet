{
  "name": "cavenet",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:server": "API_PORT=3001 bun --hot src/server/index.ts",
    "dev:client": "bunx --bun vite --port 3000 --strictPort",
    "dev": "bun run dev:server & bun run dev:client",
