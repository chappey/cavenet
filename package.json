{
  "name": "cavenet",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:server": "bun --hot src/server/index.ts",
    "dev:client": "bunx --bun vite --port 3000 --strictPort",
    "dev": "bun --parallel run dev:server dev:client",
    "db:push": "bunx drizzle-kit push",
    "db:seed": "bun run src/server/db/seed.ts",
    "db:reset": "bun run src/server/db/seed.ts --reset",
    "build": "bun vite build && tsc",
    "test": "bun test"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.31.2",
    "elysia": "^1.1.2",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/bun": "^1.1.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "drizzle-kit": "^0.22.8",
    "typescript": "^5.5.3",
    "vite": "^5.3.1"
  }
}
