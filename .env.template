# Copy this file to .env and fill in your local values.
# Bun loads .env from the current working directory, so running commands from the repo root will pick this up automatically.

GEMINI_API_KEY=
# Optional: override the backend AI model.
# Recommended values:
# - gemini-2.5-flash (default)
# - gemini-2.0-flash
# - any other Gemini model you have access to
GEMINI_MODEL=gemini-2.5-flash

# Optional: disable all remote AI requests and use local fallback behavior.
CAVENET_DISABLE_AI=0

# Optional server port override.
API_PORT=3001